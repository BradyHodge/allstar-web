# ─────────────────────────────────────────────────────────
#  AllStar Web Transceiver - Configuration
#  Copy to .env and fill in your values.
#  Users supply their own node credentials via the web UI.
# ─────────────────────────────────────────────────────────

# Your VPS domain name - must have DNS pointing to this server
# HTTPS cert is auto-provisioned via Let's Encrypt
DOMAIN=radio.example.com

# AMI secret for API → Asterisk control (change this!)
AMI_SECRET=changeme-generate-a-random-string

# Encryption key for storing user AllStar passwords at rest.
# Must be EXACTLY 32 characters. Change this before first run!
ENCRYPTION_KEY=changeme-must-be-32-chars-exactly

# STUN server for WebRTC ICE negotiation (default is fine)
STUN_SERVER=stun.l.google.com:19302
